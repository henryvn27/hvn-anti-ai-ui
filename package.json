{
  "name": "anti-ai-ui",
  "version": "0.1.0",
  "description": "Human-first React UI patterns that avoid generic AI-generated frontend aesthetics.",
  "type": "module",
  "license": "MIT",
  "author": "Henry Van Ness",
  "repository": {
    "type": "git",
    "url": "https://github.com/henryvn27/anti-ai-ui.git"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:lib && npm run build:docs",
    "build:lib": "tsc -p tsconfig.build.json",
    "build:docs": "vite build",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run lint && npm run build:lib"
  },
  "peerDependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.0.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.4.5",
    "vite": "^8.0.14"
  }
}
